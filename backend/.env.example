# ── Base de datos ─────────────────────────────────────────
DATABASE_URL="postgresql://unphu_user:CHANGE_ME@localhost:5432/unphu_tesis_db"

# ── JWT ───────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_min_32_chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME_min_32_chars_different"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Servidor ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Email (SMTP) ──────────────────────────────────────────
# Gmail: activar "Contraseñas de aplicación" en la cuenta Google
# UNPHU: usar servidor SMTP institucional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-cuenta@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM="UNPHU Tesis <noreply@unphu.edu.do>"

# ── Cloudflare R2 (almacenamiento de documentos) ──────────
# Panel: https://dash.cloudflare.com → R2 → Create bucket
# Nombre del bucket recomendado: unphu-tesis-docs
# Access Key: R2 → Manage R2 API Tokens → Create API Token
R2_ACCOUNT_ID=tu_account_id_de_cloudflare
R2_ACCESS_KEY_ID=tu_r2_access_key
R2_SECRET_ACCESS_KEY=tu_r2_secret_key
R2_BUCKET_NAME=unphu-tesis-docs
# Para acceso público: activar "Public Access" en el bucket R2
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev

# ── Anthropic (asistente AI en editor de tesis) ───────────
# Obtener en: https://console.anthropic.com → API Keys
# Si no se configura, el botón "Asistente AI" devuelve 503
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# ── Rate limiting ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Docker (solo para docker-compose) ────────────────────
POSTGRES_USER=unphu_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=unphu_tesis_db
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# ── Calificación ─────────────────────────────────────────
GRADE_PASS_THRESHOLD=70
