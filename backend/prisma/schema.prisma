// ============================================================
// Prisma Schema – Plataforma de Tesis UNPHU
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enumeraciones ───────────────────────────────────────────

enum UserRole {
  STUDENT
  ADVISOR
  COORDINATOR
  ADMIN
  EVALUATOR
  DIRECTOR
  REGISTRO
  COBROS
  CAJA
  JURADO
}

enum WorkType {
  TESIS
  MONOGRAFICO
}

enum ThesisStatus {
  POSTULATION            // Estudiante se postula
  ACADEMIC_VALIDATION    // Coordinador valida elegibilidad
  PROPOSAL_FORM          // Estudiante llena formulario de propuesta (con firma)
  PROPOSAL_REVIEW        // Coordinador revisa el formulario
  PROPOSAL_APPROVED      // Coordinador aprueba el formulario
  REGISTRO_PROCESSING    // Registro introduce datos en su sistema
  REGISTERED             // Registro libera el formulario → va a Cobros
  COBROS_PROCESSING      // Cobros digita el monto a pagar → va a Caja
  CAJA_PENDING           // Caja recibe el monto y espera confirmación de pago
  PAYMENT_CONFIRMED      // Caja confirma el pago recibido
  FACULTY_MEETING        // Coordinador coordina reunión con Director
  DRAFT_IN_PROGRESS      // Estudiante desarrolla el anteproyecto
  DRAFT_UNDER_REVIEW     // Director revisa / propone correcciones
  DRAFT_APPROVED         // Director aprueba el anteproyecto
  ADVISOR_ASSIGNED       // Coordinador asigna asesor
  WORK_STARTED           // Asesor inicia el trabajo
  IN_DEVELOPMENT         // Trabajo de tesis en desarrollo
  ADVANCES_SUBMITTED     // Asesor valida avances
  ADVISOR_FEEDBACK       // Asesor retroalimenta
  WORK_COMPLETED         // Asesor aprueba todos los módulos
  PRESENTATION_SCHEDULED // Coordinador programa la presentación y asigna jurado
  PRESENTATION_DONE      // Presentación realizada
  GRADED                 // Jurado califica
  APPROVED               // Trabajo aprobado
  PUBLISHED              // Publicado en repositorio
  REJECTED               // Rechazado en cualquier etapa
  PENDING_PAYMENT        // Legacy – mantenido para compatibilidad
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  REJECTED
}

enum AdvanceStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  NEEDS_REVISION
}

enum DocumentType {
  PROPOSAL
  RECEIPT
  DRAFT
  FINAL_WORK
  PRESENTATION
  CERTIFICATE
  OTHER
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  STATUS_CHANGE
  FILE_UPLOAD
  FILE_DOWNLOAD
  PAYMENT_CONFIRM
}

// ─── ThesisOS — Estado de nodo ───────────────────────────────

enum NodeStatus {
  DRAFT
  IN_PROGRESS
  PENDING_AI
  PENDING_REVIEW
  RETURNED
  APPROVED
  BLOCKED
  PUBLISHED
  ARCHIVED
}

// ─── ThesisOS — Tipo de bloque ───────────────────────────────

enum BlockType {
  PARAGRAPH
  HEADING
  BULLETLIST
  ORDEREDLIST
  TABLE
  IMAGE
  CODE
  BLOCKQUOTE
  DIVIDER
  CALLOUT
  EQUATION
  MERMAID
  FIGURE
  FOOTNOTE
  CITATION
  REFERENCE_LIST
  TOC
  EMBED
  VIDEO
  ATTACHMENT
}

enum CitationStyle {
  APA7
  IEEE
  CHICAGO
  MLA
  VANCOUVER
  HARVARD
}

// ─── Usuario base ────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String
  role                 UserRole  @default(STUDENT)
  firstName            String
  lastName             String
  phone                String?
  isActive             Boolean   @default(true)
  emailVerified        Boolean   @default(false)
  emailVerifyToken     String?   @unique
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  lastLogin            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  student              Student?
  advisor              Advisor?
  auditLogs            AuditLog[]
  notifications        Notification[]
  messages             Message[]
  advanceComments      AdvanceComment[]
  templates            DocumentTemplate[]

  @@map("users")
}

// ─── Carrera ─────────────────────────────────────────────────

model Career {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students    Student[]
  thesisWorks ThesisWork[]
  templates   DocumentTemplate[]

  @@map("careers")
}

// ─── Estudiante ──────────────────────────────────────────────

model Student {
  id              String   @id @default(uuid())
  userId          String   @unique
  matricula       String   @unique
  careerId        String
  enrollmentYear  Int
  creditsApproved Int      @default(0)
  gpa             Float?
  isEligible      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  career          Career       @relation(fields: [careerId], references: [id])
  thesisWorks     ThesisWork[]

  @@map("students")
}

// ─── Asesor ──────────────────────────────────────────────────

model Advisor {
  id           String   @id @default(uuid())
  userId       String   @unique
  department   String?
  specialties  String[]
  maxWorkload  Int      @default(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thesisWorks  ThesisWork[]

  @@map("advisors")
}

// ─── Trabajo de Grado ────────────────────────────────────────

model ThesisWork {
  id              String       @id @default(uuid())
  studentId       String
  advisorId       String?
  careerId        String
  title           String
  type            WorkType
  status          ThesisStatus @default(POSTULATION)
  abstract        String?      @db.Text
  keywords        String[]
  year            Int?
  firma           String?      // Firma digital del estudiante en la propuesta
  definitiveTopic String?      // Tema definitivo acordado en reunión con Director
  submittedAt     DateTime     @default(now())
  approvedAt      DateTime?
  publishedAt     DateTime?
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  student         Student        @relation(fields: [studentId], references: [id])
  advisor         Advisor?       @relation(fields: [advisorId], references: [id])
  career          Career         @relation(fields: [careerId], references: [id])
  statusHistory   StatusHistory[]
  payment         Payment?
  draft           Draft?
  advances        Advance[]
  documents       Document[]
  presentation    Presentation?
  grades          Grade[]
  meetings        Meeting[]
  messages        Message[]
  thesisDocuments ThesisDocument[]

  @@index([status])
  @@index([studentId])
  @@index([advisorId])
  @@index([careerId])
  @@index([status, careerId])
  @@map("thesis_works")
}

// ─── Historial de estados ─────────────────────────────────────

model StatusHistory {
  id           String        @id @default(uuid())
  thesisWorkId String
  fromStatus   ThesisStatus?
  toStatus     ThesisStatus
  changedById  String
  notes        String?
  createdAt    DateTime      @default(now())

  thesisWork   ThesisWork    @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)

  @@map("status_history")
}

// ─── Pago ────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(uuid())
  thesisWorkId      String        @unique
  amount            Decimal       @default(0) @db.Decimal(10, 2)
  currency          String        @default("DOP")
  status            PaymentStatus @default(PENDING)
  receiptUrl        String?
  receiptFileName   String?
  amountSetById     String?       // Usuario de Cobros que digitó el monto
  amountSetAt       DateTime?     // Cuándo Cobros fijó el monto
  confirmedById     String?       // Usuario de Caja que confirmó el pago
  confirmedAt       DateTime?
  rejectionReason   String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  thesisWork        ThesisWork    @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Anteproyecto ────────────────────────────────────────────

model Draft {
  id              String       @id @default(uuid())
  thesisWorkId    String       @unique
  title           String
  introduction    String?      @db.Text
  justification   String?      @db.Text
  objectives      String?      @db.Text
  methodology     String?      @db.Text
  timeline        String?      @db.Text
  bibliography    String?      @db.Text
  fileUrl         String?
  fileName        String?
  version         Int          @default(1)
  reviewedById    String?
  reviewedAt      DateTime?
  approvedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  thesisWork      ThesisWork   @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)

  @@map("drafts")
}

// ─── Avance ──────────────────────────────────────────────────

model Advance {
  id           String        @id @default(uuid())
  thesisWorkId String
  version      Int
  title        String
  description  String        @db.Text
  fileUrl      String?
  fileName     String?
  status       AdvanceStatus @default(SUBMITTED)
  submittedAt  DateTime      @default(now())
  reviewedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  thesisWork   ThesisWork    @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)
  comments     AdvanceComment[]

  @@map("advances")
}

// ─── Comentario de avance ────────────────────────────────────

model AdvanceComment {
  id         String   @id @default(uuid())
  advanceId  String
  authorId   String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  advance    Advance  @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id])

  @@map("advance_comments")
}

// ─── Reunión ─────────────────────────────────────────────────

model Meeting {
  id           String     @id @default(uuid())
  thesisWorkId String
  scheduledAt  DateTime
  location     String?
  virtualLink  String?
  agenda       String?    @db.Text
  notes        String?    @db.Text
  attendees    String[]
  completed    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  thesisWork   ThesisWork @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)

  @@map("meetings")
}

// ─── Presentación ────────────────────────────────────────────

model Presentation {
  id            String     @id @default(uuid())
  thesisWorkId  String     @unique
  scheduledAt   DateTime
  location      String?
  virtualLink   String?
  juryMembers   String[]
  notes         String?
  completed     Boolean    @default(false)
  completedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  thesisWork    ThesisWork @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)
  grades        Grade[]

  @@map("presentations")
}

// ─── Calificación ────────────────────────────────────────────

model Grade {
  id             String        @id @default(uuid())
  thesisWorkId   String
  presentationId String?
  evaluatorId    String
  evaluatorName  String
  writtenGrade   Float?
  oralGrade      Float?
  finalGrade     Float?
  approved       Boolean?
  observations   String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  thesisWork     ThesisWork    @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)
  presentation   Presentation? @relation(fields: [presentationId], references: [id])

  @@map("grades")
}

// ─── Documento ───────────────────────────────────────────────

model Document {
  id           String       @id @default(uuid())
  thesisWorkId String
  type         DocumentType
  name         String
  fileUrl      String
  fileKey      String
  fileSize     Int?
  mimeType     String?
  uploadedById String
  isPublic     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  thesisWork   ThesisWork   @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─── Notificación ────────────────────────────────────────────

model Notification {
  id        String              @id @default(uuid())
  userId    String
  title     String
  message   String              @db.Text
  type      String
  channel   NotificationChannel @default(IN_APP)
  isRead    Boolean             @default(false)
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Chat / Mensajes ─────────────────────────────────────────

model Message {
  id           String     @id @default(uuid())
  thesisWorkId String
  senderId     String
  senderName   String
  senderRole   UserRole
  content      String     @db.Text
  isRead       Boolean    @default(false)
  createdAt    DateTime   @default(now())

  thesisWork   ThesisWork @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)
  sender       User       @relation(fields: [senderId], references: [id])

  @@map("messages")
}

// ─── Bitácora de auditoría ───────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── ThesisOS — Documento Paramétrico ────────────────────────
//
//  Un ThesisWork puede tener DOS documentos: ANTEPROYECTO y TESIS.
//  Cada documento es un árbol de DocumentNode (profundidad ilimitada).
//  Los nodos contienen bloques de contenido TipTap.
//  Las plantillas (TemplateNode) definen la estructura inicial del árbol.

// ─── Documento de tesis ──────────────────────────────────────

model ThesisDocument {
  id            String        @id @default(uuid())
  thesisWorkId  String
  docType       String        @default("THESIS")  // THESIS | ANTEPROYECTO | CUSTOM
  title         String
  citationStyle CitationStyle @default(APA7)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  thesisWork    ThesisWork    @relation(fields: [thesisWorkId], references: [id], onDelete: Cascade)
  nodes         DocumentNode[]

  @@unique([thesisWorkId, docType])
  @@map("thesis_documents")
}

// ─── Nodo de documento (árbol de profundidad ilimitada) ──────

model DocumentNode {
  id          String     @id @default(uuid())
  documentId  String
  parentId    String?
  order       Float      @default(0)
  name        String     // "Marco Teórico", "Capítulo 1", "useEffect", etc.
  nodeType    String     @default("section") // chapter | section | subsection | any label
  status      NodeStatus @default(DRAFT)
  isRequired  Boolean    @default(false)
  isOptional  Boolean    @default(false)
  metadata    Json?      // { minWords, maxWords, rubric, guidance, templateNodeId }
  lockedAt    DateTime?
  lockedById  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  document        ThesisDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parent          DocumentNode?       @relation("NodeTree", fields: [parentId], references: [id])
  children        DocumentNode[]      @relation("NodeTree")
  blocks          Block[]
  comments        NodeComment[]
  history         NodeStatusHistory[]
  versions        NodeVersion[]
  sourceRelations NodeRelation[]      @relation("RelationSource")
  targetRelations NodeRelation[]      @relation("RelationTarget")

  @@index([documentId])
  @@index([parentId])
  @@map("document_nodes")
}

// ─── Historial de estado de nodo ─────────────────────────────

model NodeStatusHistory {
  id          String     @id @default(uuid())
  nodeId      String
  fromStatus  NodeStatus?
  toStatus    NodeStatus
  changedById String
  notes       String?
  createdAt   DateTime   @default(now())

  node        DocumentNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@map("node_status_history")
}

// ─── Comentario de nodo (tipo Google Docs) ───────────────────

model NodeComment {
  id          String   @id @default(uuid())
  nodeId      String
  blockId     String?
  parentId    String?
  authorId    String
  authorName  String
  content     String   @db.Text
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  priority    String   @default("NORMAL")
  mentions    String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  node         DocumentNode   @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  parent       NodeComment?   @relation("NodeCommentReplies", fields: [parentId], references: [id])
  replies      NodeComment[]  @relation("NodeCommentReplies")

  @@map("node_comments")
}

// ─── Bloque de contenido (TipTap JSON) ───────────────────────

model Block {
  id         String    @id @default(uuid())
  nodeId     String
  type       BlockType @default(PARAGRAPH)
  order      Float     @default(0)
  content    Json
  authorId   String
  wordCount  Int       @default(0)
  metadata   Json?
  isDeleted  Boolean   @default(false)
  lockedBy   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  node       DocumentNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  versions   BlockVersion[]

  @@map("blocks")
}

// ─── Versión de bloque (versionado tipo Git) ─────────────────

model BlockVersion {
  id          String   @id @default(uuid())
  blockId     String
  versionNum  Int
  content     Json
  diff        Json?
  authorId    String
  message     String?
  trigger     String   @default("MANUAL")
  wordCount   Int      @default(0)
  createdAt   DateTime @default(now())

  block       Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, versionNum])
  @@map("block_versions")
}

// ─── Snapshot de nodo (versión completa) ─────────────────────

model NodeVersion {
  id          String       @id @default(uuid())
  nodeId      String
  versionNum  Int
  label       String?
  snapshot    Json         // serialized: name, metadata, blocks[]
  createdById String
  createdAt   DateTime     @default(now())

  node        DocumentNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([nodeId, versionNum])
  @@map("node_versions")
}

// ─── Relación entre nodos (trazabilidad) ─────────────────────

model NodeRelation {
  id        String       @id @default(uuid())
  sourceId  String
  targetId  String
  relType   String       @default("DERIVED_FROM") // DERIVED_FROM | REFERENCES | REPLACES
  createdAt DateTime     @default(now())

  source    DocumentNode @relation("RelationSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    DocumentNode @relation("RelationTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@map("node_relations")
}

// ─── Event Store ─────────────────────────────────────────────

model DocEvent {
  id            String   @id @default(uuid())
  aggregateId   String
  aggregateType String
  eventType     String
  payload       Json
  userId        String
  occurredAt    DateTime @default(now())

  @@index([aggregateId, aggregateType])
  @@map("doc_events")
}

// ─── Templates de Documento ───────────────────────────────────
//
//  Un DocumentTemplate define la estructura inicial de un documento.
//  Los TemplateNode forman un árbol de profundidad ilimitada.
//  El Coordinador puede crear plantillas por facultad/carrera/tipo.

model DocumentTemplate {
  id          String         @id @default(uuid())
  name        String
  description String?
  docType     String         @default("THESIS") // THESIS | ANTEPROYECTO | CUSTOM
  careerId    String?
  isActive    Boolean        @default(true)
  isDefault   Boolean        @default(false)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  career      Career?        @relation(fields: [careerId], references: [id])
  createdBy   User           @relation(fields: [createdById], references: [id])
  nodes       TemplateNode[]

  @@map("document_templates")
}

// ─── Nodo de plantilla (árbol) ───────────────────────────────

model TemplateNode {
  id         String           @id @default(uuid())
  templateId String
  parentId   String?
  order      Float            @default(0)
  name       String
  nodeType   String           @default("section") // chapter | section | subsection | custom
  isRequired Boolean          @default(false)
  isOptional Boolean          @default(false)
  metadata   Json?            // { minWords, maxWords, guidance, rubric }

  template   DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent     TemplateNode?    @relation("TemplateNodeTree", fields: [parentId], references: [id])
  children   TemplateNode[]   @relation("TemplateNodeTree")

  @@index([templateId])
  @@index([parentId])
  @@map("template_nodes")
}
